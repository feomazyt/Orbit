{
  "info": {
    "name": "Orbit API",
    "description": "Kolekcja do testowania API Orbit: auth → boards → lists → cards → comments. Zmienne: baseUrl, accessToken (ustawiane po login/register).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "accessToken", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "listId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "commentId", "value": "" }
  ],
  "item": [
    {
      "name": "1. Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"Test User\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Rejestracja. Odpowiedź zawiera token — zapisany do zmiennej accessToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('accessToken', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"password123\"\n}"
            },
            "url": "{{baseUrl}}/auth/login",
            "description": "Logowanie. Odpowiedź zawiera token — zapisany do zmiennej accessToken."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const json = pm.response.json();",
                  "if (json.token) { pm.collectionVariables.set('accessToken', json.token); }"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "url": "{{baseUrl}}/auth/logout",
            "description": "Wylogowanie (token unieważniany po stronie klienta)."
          }
        }
      ]
    },
    {
      "name": "2. Boards",
      "item": [
        {
          "name": "GET Boards (list)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards?limit=20&offset=0",
            "description": "Lista tablic użytkownika. Query: limit, offset, title (opcjonalnie)."
          }
        },
        {
          "name": "POST Board (create)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Moja tablica\",\n  \"description\": \"Opis tablicy\"\n}"
            },
            "url": "{{baseUrl}}/boards",
            "description": "Tworzenie tablicy. Zwraca obiekt z id — użyj boardId w kolejnych requestach."
          }
        },
        {
          "name": "GET Board by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}",
            "description": "Pojedyncza tablica. Nieprawidłowy/cudzy boardId → 404."
          }
        },
        {
          "name": "PUT Board (update)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Zaktualizowany tytuł\",\n  \"description\": \"Nowy opis\"\n}"
            },
            "url": "{{baseUrl}}/boards/{{boardId}}",
            "description": "Aktualizacja tablicy. Nieprawidłowy boardId → 404."
          }
        },
        {
          "name": "DELETE Board",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}",
            "description": "Usunięcie tablicy. Nieprawidłowy boardId → 404."
          }
        }
      ]
    },
    {
      "name": "3. Lists",
      "item": [
        {
          "name": "GET Lists by board",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards/{{boardId}}/lists",
            "description": "Listy danej tablicy. Cudzy/nieistniejący boardId → 404."
          }
        },
        {
          "name": "POST List on board",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Do zrobienia\",\n  \"position\": 0\n}"
            },
            "url": "{{baseUrl}}/boards/{{boardId}}/lists",
            "description": "Utworzenie listy na tablicy. position opcjonalne."
          }
        },
        {
          "name": "PUT List (update)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"W toku\",\n  \"position\": 1\n}"
            },
            "url": "{{baseUrl}}/lists/{{listId}}",
            "description": "Aktualizacja listy. Cudza/nieistniejąca lista → 404."
          }
        },
        {
          "name": "PATCH Lists reorder",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "[\n  { \"id\": \"{{listId}}\", \"position\": 0 }\n]"
            },
            "url": "{{baseUrl}}/lists/reorder",
            "description": "Zmiana kolejności list (body: [{ id, position }])."
          }
        },
        {
          "name": "DELETE List",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/lists/{{listId}}",
            "description": "Usunięcie listy. Cudza/nieistniejąca lista → 404."
          }
        }
      ]
    },
    {
      "name": "4. Cards",
      "item": [
        {
          "name": "GET Cards by list",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/cards?listId={{listId}}",
            "description": "Karty danej listy. Query: listId (wymagane), limit, offset."
          }
        },
        {
          "name": "POST Card (create)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Nowa karta\",\n  \"listId\": \"{{listId}}\",\n  \"description\": \"Opis karty\",\n  \"position\": 0\n}"
            },
            "url": "{{baseUrl}}/cards",
            "description": "Utworzenie karty. listId wymagane."
          }
        },
        {
          "name": "GET Card by id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}",
            "description": "Pojedyncza karta. Cudza/nieistniejąca → 404."
          }
        },
        {
          "name": "PATCH Card (update)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Zaktualizowana karta\",\n  \"description\": \"Nowy opis\"\n}"
            },
            "url": "{{baseUrl}}/cards/{{cardId}}",
            "description": "Aktualizacja karty. Opcjonalnie: dueDate, position."
          }
        },
        {
          "name": "POST Card move",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"listId\": \"{{listId}}\",\n  \"position\": 0\n}"
            },
            "url": "{{baseUrl}}/cards/{{cardId}}/move",
            "description": "Przeniesienie karty do innej listy."
          }
        },
        {
          "name": "DELETE Card",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}",
            "description": "Usunięcie karty. Cudza/nieistniejąca → 404."
          }
        }
      ]
    },
    {
      "name": "5. Comments",
      "item": [
        {
          "name": "GET Comments by card",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/cards/{{cardId}}/comments?limit=20&offset=0",
            "description": "Komentarze karty. Query: limit, offset."
          }
        },
        {
          "name": "POST Comment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"To jest komentarz do karty.\"\n}"
            },
            "url": "{{baseUrl}}/cards/{{cardId}}/comments",
            "description": "Dodanie komentarza do karty."
          }
        },
        {
          "name": "PUT Comment (update)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{accessToken}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Zaktualizowana treść komentarza.\"\n}"
            },
            "url": "{{baseUrl}}/comments/{{commentId}}",
            "description": "Edycja komentarza. Cudzy/nieistniejący → 404."
          }
        },
        {
          "name": "DELETE Comment",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/comments/{{commentId}}",
            "description": "Usunięcie komentarza. Cudzy/nieistniejący → 404."
          }
        }
      ]
    },
    {
      "name": "Scenariusze (401 / 404)",
      "item": [
        {
          "name": "GET Boards — brak tokena (401)",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{baseUrl}}/boards",
            "description": "Bez nagłówka Authorization. Oczekiwana odpowiedź: 401 Unauthorized."
          }
        },
        {
          "name": "GET Board — zły boardId (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards/00000000-0000-0000-0000-000000000000",
            "description": "Nieistniejący lub cudzy board. Oczekiwana odpowiedź: 404 Not Found (API zwraca 404 zamiast 403)."
          }
        },
        {
          "name": "GET Lists — zły boardId (404)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{accessToken}}" }],
            "url": "{{baseUrl}}/boards/00000000-0000-0000-0000-000000000000/lists",
            "description": "Listy nieistniejącej/cudzej tablicy. Oczekiwana odpowiedź: 404."
          }
        }
      ]
    }
  ]
}
