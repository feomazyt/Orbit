# Skopiuj do .env i uzupełnij (bez commitowania .env).

# Baza PostgreSQL – używane przez API i MikroORM (migracje)
DB_HOST=localhost
DB_PORT=5432

# Opcjonalnie (zgodne z docker-compose)
POSTGRES_USER=orbit
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=orbit
DATABASE_URL=postgresql://user:password@localhost:5432/orbit
