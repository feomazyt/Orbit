# Skopiuj do .env i uzupełnij (bez commitowania .env).

# Opcjonalnie (zgodne z docker-compose). User i hasło muszą być takie same jak w PostgreSQL.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=orbit
POSTGRES_PASSWORD=your_password_here
POSTGRES_DB=orbit
# Jeśli ustawisz DATABASE_URL, ma pierwszeństwo. Użyj tych samych user/hasło co w Postgres.
# DATABASE_URL=postgresql://orbit:your_password_here@localhost:5432/orbit

# JWT – wymagane w produkcji
JWT_SECRET=change-me-in-production
# JWT_ACCESS_EXPIRES_IN=1h

# Redis (dla kolejki webhooków – Bull)
REDIS_URL=redis://localhost:6379
# W Dockerze użyj redis://redis:6379

# Front w produkcji (opcjonalnie – gdy API pod innym adresem)
# VITE_API_BASE_URL=/api
# NODE_ENV=production
